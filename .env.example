NODE_ENV=production
CYRUS_ENABLE_PYTHON=0
# Comms ML sidecar (server/comms/ml_service.py) — sentiment, anomalies, etc.
CYRUS_ENABLE_COMMS_ML=0
CYRUS_LIVE_PORT=8080
DATABASE_URL=postgresql://user:pass@host/db
OPENAI_API_KEY=sk-...
ENCRYPTION_SECRET=<generate-random-32-char>
ENCRYPTION_SALT=<generate-random-16-char>
SESSION_SECRET=<generate-random-32-char>
ADMIN_ACCESS_CODE=<generate-random-16-char>
USER_ACCESS_CODE=<generate-random-16-char>
PUBLIC_BASE_URL=https://cybernetic-legion-production.up.railway.app
CORS_ORIGIN=https://cybernetic-legion-production.up.railway.app
ENABLE_REUSE_PORT=false

# CYRUS Comm P2P+ (Comms tab) — optional TURN for production WebRTC behind strict NAT
# TURN_URLS=turn:your-turn-host:3478,turns:your-turn-host:5349
# TURN_USERNAME=cyrus
# TURN_CREDENTIAL=change-me
