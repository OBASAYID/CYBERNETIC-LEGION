# CYRUS — universal multi-device deployment template
# Copy to .env and set values for your environment (never commit secrets).

NODE_ENV=production
CYRUS_ENABLE_PYTHON=0
CYRUS_ENABLE_COMMS_ML=0

# ── Public origin (required for mobile, LAN, and multi-device) ──
# Must match the URL users open in the browser (HTTPS in production).
PUBLIC_BASE_URL=https://your-domain.example
BASE_URL=https://your-domain.example
CORS_ORIGIN=https://your-domain.example
PUBLIC_PROTOCOL=https
PUBLIC_DOMAIN=your-domain.example

# ── HTTP server ──
CYRUS_LIVE_PORT=8080
SERVER_HOST=0.0.0.0
ENABLE_REUSE_PORT=false

# ── Database & sessions (required for multi-device account sync) ──
DATABASE_URL=postgresql://user:pass@host:5432/cyrus
CYRUS_SESSION_STORE=postgresql
SESSION_SECRET=<generate-random-32-char>
CYRUS_SESSION_TOKEN_SECRET=<generate-random-32-char>

# ── Auth ──
ADMIN_ACCESS_CODE=<generate-random-16-char>
USER_ACCESS_CODE=<generate-random-16-char>
ENCRYPTION_SECRET=<generate-random-32-char>
ENCRYPTION_SALT=<generate-random-16-char>

# ── External services (set service DNS — not 127.0.0.1 in production) ──
CYRUS_AI_URL=http://cyrus-ai:8001
COMMS_ML_URL=http://comms-ml:5002
REDIS_URL=redis://redis:6379
QUANTUM_BRIDGE_URL=http://quantum-bridge:5001

# ── WebRTC / comms (cross-network + multi-device calls) ──
TURN_URLS=turn:turn.example:3478,turns:turn.example:5349
TURN_USERNAME=cyrus
TURN_CREDENTIAL=change-me
# Or time-limited creds: TURN_SECRET=...
CYRUS_SFU_ANNOUNCED_IP=<public-ipv4-of-api-host>
# After npm ci: npm run sfu:install && npm run sfu:verify
CYRUS_SFU_RTC_MIN_PORT=40000
CYRUS_SFU_RTC_MAX_PORT=49999
# CYRUS_DISABLE_SFU=true
# CYRUS_COMM_WS_TOKEN=optional-signaling-lock
# CYRUS_COMM_SOCKET_WS=true

# ── Optional split-origin UI (CDN static + API host) ──
# VITE_CYRUS_API_BASE=https://api.your-domain.example
# VITE_CYRUS_COMM_WS_TOKEN=<matches CYRUS_COMM_WS_TOKEN>

# ── OpenAI (optional) ──
OPENAI_API_KEY=sk-...
