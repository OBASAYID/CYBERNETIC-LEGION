NODE_ENV=production
CYRUS_ENABLE_PYTHON=0
CYRUS_LIVE_PORT=8080
DATABASE_URL=postgresql://user:pass@host/db
OPENAI_API_KEY=sk-...
ENCRYPTION_SECRET=<generate-random-32-char>
ENCRYPTION_SALT=<generate-random-16-char>
SESSION_SECRET=<generate-random-32-char>
ADMIN_ACCESS_CODE=<generate-random-16-char>
USER_ACCESS_CODE=<generate-random-16-char>
PUBLIC_BASE_URL=https://167-233-36-99.sslip.io
# Mobile PWA: install from PUBLIC_BASE_URL — UI caches on device, API stays on server.
# Do not set VITE_CYRUS_API_BASE for standard same-origin production install.
CORS_ORIGIN=https://167-233-36-99.sslip.io
# Multi-model intelligence (GPT, Claude, Gemini, Grok, local Ollama)
CYRUS_MULTI_MODEL_STRATEGY=cascade
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash-exp
XAI_API_KEY=
XAI_MODEL=grok-beta
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=cyrus-general
OLLAMA_CODE_MODEL=cyrus-code

# Comms scale (500k user path)
REDIS_URL=redis://127.0.0.1:6379
CYRUS_MAX_CONCURRENT_USERS=500000
CYRUS_SFU_MAX_PARTICIPANTS=64
CYRUS_SFU_WORKER_COUNT=2
CYRUS_SFU_RTC_MIN_PORT=40000
CYRUS_SFU_RTC_MAX_PORT=40100
CYRUS_SFU_ANNOUNCED_IP=
CYRUS_COMM_PUBLIC_TURN=false
TURN_URLS=turn:your-host:3478,turns:your-host:5349
TURN_SECRET=
TURN_EXTERNAL_IP=
FCM_SERVER_KEY=
