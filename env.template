# CYRUS runtime environment template (safe to commit)
# Copy values into your platform env settings (Render, etc.) or local `.env`.

# Core runtime
NODE_ENV=production
# Render and most PaaS inject PORT (often 10000). Do not set CYRUS_LIVE_PORT to a
# different value there — the app syncs CYRUS_LIVE_PORT to PORT on conflict.
# PORT=
# CYRUS_LIVE_PORT=
SERVER_HOST=0.0.0.0
CYRUS_UI_ROOT=cyrus-ui
CYRUS_ENABLE_PYTHON=0
ENABLE_REUSE_PORT=false

# Security and access (set real values)
SESSION_SECRET=replace-with-long-random-secret
ADMIN_ACCESS_CODE=replace-admin-code
USER_ACCESS_CODE=replace-user-code

# Data/backend
DATABASE_URL=postgresql://user:password@host:5432/cyrus_ai
CYRUS_SESSION_STORE=memory

# AI configuration (at least one API key path should be configured)
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_INTEGRATIONS_OPENAI_MODEL=gpt-4o-mini

# Optional integrations
ELEVENLABS_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=
NEWS_API_KEY=
QUANTUM_BRIDGE_URL=
COMMS_ML_URL=
REDIS_URL=

# Networking/base URL
PUBLIC_PROTOCOL=https
PUBLIC_DOMAIN=your-domain.example
BASE_URL=https://your-domain.example
CORS_ORIGIN=*

# Keep unset unless you intentionally override static build output detection.
# FRONTEND_STATIC_DIR=
