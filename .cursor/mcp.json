{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN=${env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "ghcr.io/github/github-mcp-server:0.33.0"
      ]
    },
    "cyrus-asset-ingest": {
      "command": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [
        "${workspaceFolder}/server/mcp/cyrus-asset-ingest-server.ts"
      ],
      "env": {
        "CYRUS_ML_ASSETS": "true",
        "CYRUS_OPENAI_INDEPENDENT": "true",
        "CYRUS_ML_KNOWLEDGE_SYNC": "true"
      }
    },
    "cyrus-data-collection": {
      "command": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [
        "${workspaceFolder}/server/mcp/cyrus-data-collection-server.ts"
      ],
      "env": {
        "CYRUS_INGEST_SCRAPED_ASSETS": "true"
      }
    },
    "cyrus-intelligence": {
      "command": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": [
        "${workspaceFolder}/server/mcp/cyrus-intelligence-server.ts"
      ],
      "env": {
        "CYRUS_INTELLIGENCE_AUTO": "0",
        "CYRUS_OPENAI_INDEPENDENT": "true",
        "CYRUS_ML_ASSETS": "true"
      }
    }
  }
}
