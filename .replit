modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libxcrypt", "pkg-config", "qhull", "tcl", "tk", "unzip", "xsimd"]

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_log_in_with_replit:2.0.0"]
stack = "GAMESTACK_JS"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start CYRUS"

[[workflows.workflow]]
name = "Start CYRUS"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CYRUS_SINGLE_ORIGIN=1 NODE_ENV=development CYRUS_UI_ROOT=cyrus-ui TMPDIR=/tmp SERVER_HOST=0.0.0.0 tsx server/index.ts"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
# Match [[ports]] / waitForPort 5000 so `npm run dev` binds the webview target.
PORT = "5000"
ALPACA_ENVIRONMENT = "live"
SERVER_HOST = "0.0.0.0"
CYRUS_SINGLE_ORIGIN = "1"
CYRUS_UI_ROOT = "cyrus-ui"
TMPDIR = "/tmp"
NODE_ENV = "development"
TRUST_PROXY = "1"
