# Automatic HTTPS via sslip.io — 167.233.36.99 → 167-233-36-99.sslip.io
# Replace SITE_HOST in scripts/setup-hetzner-https.sh if your public IP changes.

{$SITE_HOST} {
	# Per-request body cap (single chunk + multipart overhead; comms uses ~16 MiB chunks).
	request_body {
		max_size 32MB
	}

	# Socket.IO — keep WebSocket streams open (no buffering).
	@socket path /cyrus-io*
	handle @socket {
		reverse_proxy app:3020 {
			flush_interval -1
			transport http {
				read_timeout 0
				write_timeout 0
			}
		}
	}

	# Chunked comms uploads (2–4 GiB via many chunks) — long read/write windows.
	@uploads path /api/comms/upload* /api/comms/pshare/live/*
	handle @uploads {
		reverse_proxy app:3020 {
			flush_interval -1
			transport http {
				read_timeout 90m
				write_timeout 90m
			}
		}
	}

	# Media delivery — stream without compression.
	@media path /api/comms/media/*
	handle @media {
		reverse_proxy app:3020 {
			flush_interval -1
			transport http {
				read_timeout 30m
				write_timeout 30m
			}
		}
	}

	handle {
		encode gzip zstd
		reverse_proxy app:3020 {
			transport http {
				read_timeout 10m
				write_timeout 10m
			}
		}
	}
}
